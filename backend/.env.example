# ─── Backend Environment Variables ───────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git!

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# Server port (Render sets this automatically)
PORT=5000

# Your Vercel frontend URL — used by CORS
FRONTEND_URL=https://portfolio-do6j2f68v-suthansrivarmas-projects.vercel.app

# Email notifications for new contact form submissions
# Use your SMTP provider (Gmail, Brevo, SendGrid SMTP, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password_or_app_password
CONTACT_SENDER_EMAIL=your_smtp_username
# Set this to your inbox. If left empty, backend falls back to SMTP_USER.
CONTACT_RECEIVER_EMAIL=ssuthan866@gmail.com
